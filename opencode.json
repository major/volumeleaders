{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "volumeleaders": {
            "type": "local",
            "command": [
                "uv",
                "run",
                "fastmcp",
                "run",
                "src/volumeleaders/mcp/__init__.py:mcp",
                "--reload",
                "--reload-dir",
                "src/"
            ],
            "enabled": true
        }
    }
}
